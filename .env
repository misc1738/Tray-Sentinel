# Tracey's Sentinel - Environment Configuration
# SECURITY: Never commit this file to version control. Use .env.example instead.

# ===== DATABASE CONFIGURATION =====
# For SQLite (default/development): sqlite:data/sentinel.db
# For PostgreSQL (production): postgresql://user:password@host:port/database
DATABASE_URL=sqlite:data/sentinel.db

# PostgreSQL connection pool settings (only used if DATABASE_URL is PostgreSQL)
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_ECHO=false

# ===== JWT CONFIGURATION =====
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secure-randomly-generated-key-here-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== APPLICATION CONFIGURATION =====
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# ===== CORS CONFIGURATION =====
# Restrict to your specific domains in production
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# ===== EVIDENCE STORAGE =====
MAX_UPLOAD_SIZE_MB=100
EVIDENCE_ENCRYPTION_ENABLED=true

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# ===== AUDIT LOGGING =====
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# ===== LEDGER CONFIGURATION =====
LEDGER_BACKUP_ENABLED=true
LEDGER_BACKUP_INTERVAL_HOURS=24
LEDGER_VALIDATION_INTERVAL_HOURS=6

# ===== WEBHOOKS =====
WEBHOOKS_ENABLED=true
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT_SECONDS=30
