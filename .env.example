# ===== SECURITY =====

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Master password for encrypting private keys at rest
# CRITICAL: Set this to a strong password in production
MASTER_KEY_PASSWORD=your-master-key-password-change-production

# ===== FILE UPLOAD =====

# Maximum file upload size in MB (default: 100 MB)
MAX_UPLOAD_SIZE_MB=100

# ===== DATABASE =====

# SQLite database path
DATABASE_URL=data/sentinel.db

# ===== LOGGING =====

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===== DEVELOPMENT =====

# Set to true for development mode
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
